<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootswatch@5.2/dist/<%= data.theme %>/bootstrap.min.css"
            crossorigin="anonymous"
        />

        <title>Yarn Audit Report</title>
        <meta name="description" content="<%= data.summary.vulnerabilities %> overall vulnerabilities found." />

        <style>
            label {
                position: relative;

                display: block;
                padding-left: 30px;
                margin-left: -10px;

                cursor: pointer;
            }

            label:before {
                position: absolute;
                top: 50%;
                left: 10px;

                width: 0;
                height: 0;

                border-left: 8px solid currentColor;
                border-top: 8px solid transparent;
                border-bottom: 8px solid transparent;
                margin-top: -8px;

                content: '';
            }

            .card-text p:last-child {
                margin-bottom: 0;
            }

            /* PDF-specific styles */
            @media print {
                .card {
                    break-inside: avoid;
                    page-break-inside: avoid;
                }
                
                code {
                    word-break: break-all;
                    font-size: 0.8em;
                }
                
                .badge {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }
            }

            input[type='checkbox'] {
                display: none;
            }

            input[type='checkbox']:checked + h3 label:before {
                border-left: 8px solid transparent;
                border-top: 8px solid black;
                border-right: 8px solid transparent;

                margin-left: -4px;
                margin-top: -4px;
            }

            .collapsible-wrapper {
                max-height: 0;
                padding: 0;
                padding-left: 30px;
                overflow-y: auto;

                transition: max-height 0.15s ease;
            }

            input[type='checkbox']:checked + h3 + .collapsible-wrapper {
                max-height: 500px;
                padding: var(--bs-alert-padding-y) var(--bs-alert-padding-x);
            }

            h1,
            .h1 {
                font-size: calc(2.03125rem * 20 / 16);
            }
            h2,
            .h2 {
                font-size: calc(1.625rem * 20 / 16);
            }
            h3,
            .h3 {
                font-size: calc(1.421875rem * 20 / 16);
            }
            h4,
            .h4 {
                font-size: calc(1.21875rem * 20 / 16);
            }
            h5,
            .h5 {
                font-size: calc(1.015625rem * 20 / 16);
            }
            h6,
            .h6 {
                font-size: calc(0.8125rem * 20 / 16);
            }
            @media (min-width: 1200px) {
                h1,
                .h1 {
                    font-size: calc(2.03125rem * 20 / 16);
                }
                h2,
                .h2 {
                    font-size: calc(1.625rem * 20 / 16);
                }
                h3,
                .h3 {
                    font-size: calc(1.421875rem * 20 / 16);
                }
                h4,
                .h4 {
                    font-size: calc(1.21875rem * 20 / 16);
                }
                h5,
                .h5 {
                    font-size: calc(1.015625rem * 20 / 16);
                }
                h6,
                .h6 {
                    font-size: calc(0.8125rem * 20 / 16);
                }
            }
            .alert,
            .alert .h1,
            .alert .h2,
            .alert .h3,
            .alert .h4,
            .alert .h5,
            .alert .h6,
            .alert h1,
            .alert h2,
            .alert h3,
            .alert h4,
            .alert h5,
            .alert h6 {
                color: var(--bs-body-color);
            }
        </style>
    </head>

    <body>
        <div class="container">
            <div class="row my-3">
                <div class="col-md text-center">
                    <h1 class="h2">Yarn Audit Report</h1>

                    <h3 class="h5">
                        <%= formatNumber(data.vulnerabilities.length) %> unique from <%=
                        formatNumber(data.summary.vulnerabilities) %> overall vulnerabilities
                    </h3>
                    
                    <!-- Severity Overview -->
                    <div class="row mt-4 mb-4">
                        <div class="col-12">
                            <h4 class="h6 mb-3">Vulnerability Breakdown by Severity</h4>
                            <div class="d-flex justify-content-center gap-3 flex-wrap">
                                <% if (data.summary.severityCounts.critical > 0) { %>
                                <span class="badge bg-danger fs-6 px-3 py-2">
                                    Critical: <%= formatNumber(data.summary.severityCounts.critical) %>
                                </span>
                                <% } %>
                                <% if (data.summary.severityCounts.high > 0) { %>
                                <span class="badge bg-warning fs-6 px-3 py-2">
                                    High: <%= formatNumber(data.summary.severityCounts.high) %>
                                </span>
                                <% } %>
                                <% if (data.summary.severityCounts.moderate > 0) { %>
                                <span class="badge bg-info fs-6 px-3 py-2">
                                    Moderate: <%= formatNumber(data.summary.severityCounts.moderate) %>
                                </span>
                                <% } %>
                                <% if (data.summary.severityCounts.low > 0) { %>
                                <span class="badge bg-primary fs-6 px-3 py-2">
                                    Low: <%= formatNumber(data.summary.severityCounts.low) %>
                                </span>
                                <% } %>
                                <% if (data.summary.severityCounts.info > 0) { %>
                                <span class="badge bg-secondary fs-6 px-3 py-2">
                                    Info: <%= formatNumber(data.summary.severityCounts.info) %>
                                </span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <% data.vulnerabilities.forEach((vulnerability, vulnerabilityIndex)=> { %>
                <div class="col-md-12">
                    <div class="card mb-3">
                        <div class="card-body p-4">
                            <h1 class="card-title h3 d-flex align-items-center gap-2">
                                <span class="badge text-capitalize bg-<%= severityClass(vulnerability.severity) %>">
                                    <%= vulnerability.severity %>
                                </span>
                                <%= vulnerability.module_name %> - <%= vulnerability.children.Issue.split('\n')[0] %>
                            </h1>
                            <div class="row">
                                <div class="col-md-6">
                                    <ul>
                                        <li>
                                            Module:
                                            <a
                                                href="https://npmjs.com/package/<%= vulnerability.module_name %>"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                            >
                                                <%= vulnerability.module_name %>
                                            </a>
                                        </li>
                                        <% if (vulnerability.children["Tree Versions"][0]) { %>
                                        <li>Installed version: <%= vulnerability.children["Tree Versions"][0] %></li>
                                        <% } %>
                                        <li>Vulnerable: <%= vulnerability.children["Vulnerable Versions"] %></li>
                                        <li>Patched: Update to a version outside the vulnerable range</li>
                                    </ul>
                                </div>
                            </div>
                            <h3>Overview</h3>
                            <div class="card-text mb-3">
                                <%- markdown(vulnerability.children.Issue) %>
                            </div>

                            <% if (vulnerability.children.Dependents.length) { %>
                            <% if (data.isPDF) { %>
                            <!-- Expanded for PDF -->
                            <h3>Reasons this module exists</h3>
                            <div class="card-text alert alert-secondary">
                                <% vulnerability.children.Dependents.forEach((path)=> { %>
                                <div class="card-text mb-2">
                                    <code class="text-body d-block"><%= path %></code>
                                </div>
                                <% }) %>
                            </div>
                            <% } else { %>
                            <!-- Collapsible for HTML -->
                            <input id="vulnerability-reasons-<%= vulnerabilityIndex %>" type="checkbox" />
                            <h3>
                                <label for="vulnerability-reasons-<%= vulnerabilityIndex %>"
                                    >Reasons this module exists</label
                                >
                            </h3>
                            <div class="card-text alert alert-secondary collapsible-wrapper">
                                <% vulnerability.children.Dependents.forEach((path)=> { %>
                                <div class="card-text">
                                    <code class="text-body"><%= path %></code>
                                </div>
                                <% }) %>
                            </div>
                            <% } %>
                            <% } %>

                            <div class="d-flex justify-content-end">
                                <% if (vulnerability.children.URL) { %>
                                <a
                                    href="<%= vulnerability.children.URL %>"
                                    class="btn btn-md btn-primary"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    More about this vulnerability
                                </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %> <% if (data.vulnerabilities.length===0) { %>
                <div class="col-md-12 alert alert-success">Congrats!!! No vulnerabilities have been found.</div>
                <% } %>

                <h6 class="col-md-12 mb-3 pb=3 text-end">Report generated at <%= formatDate(data.reportDate) %></h6>
            </div>
        </div>
    </body>
</html>
